{
  "name": "tastebuds",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && vite build --config frontend/vite.config.ts",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:server": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/seed/seedProfiles.ts",
    "harvest": "tsx src/harvest/harvest.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.26",
    "node-cron": "^4.5.0",
    "sqlite-vec": "^0.1.9",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
