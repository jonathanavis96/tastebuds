# ── Required ────────────────────────────────────────────────────────────────

# TMDB API key (v3 "API Key", not the v4 read token).
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Claude Code OAuth token — powers the on-request recommendation curation.
# Requires a Claude Pro or Max subscription. Generate with:  claude setup-token
# (Browsing/rating works without it; only the "Generate" button needs it.)
CLAUDE_CODE_OAUTH_TOKEN=

# ── Ollama (local embeddings) ────────────────────────────────────────────────
# Bare Node on the same host:   http://localhost:11434
# Docker (Ollama on the host):  http://host.docker.internal:11434  <-- use this with docker compose
OLLAMA_URL=http://host.docker.internal:11434

# ── Optional ─────────────────────────────────────────────────────────────────

# Enables IMDb + Rotten Tomatoes ratings on curated picks.
# Free tier: 1000 req/day — get a key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# ── Harvest tuning (defaults are fine) ───────────────────────────────────────
# The nightly TMDB harvest grows the catalogue. Titles added per night is capped
# by candidate FAN-OUT (distinct not-yet-stored titles the discover pages surface),
# not by HARVEST_DAILY_TARGET — that's only an upper bound that stops ingest early.
# To add more per night, widen the fan-out below (not the daily target).
HARVEST_DAILY_TARGET=500          # max NEW titles ingested per harvest run (a cap, not a goal)
HARVEST_MAX_PAGE=100              # deepest TMDB discover page each bucket sweeps before wrapping
HARVEST_PAGES_PER_BUCKET=4        # consecutive cursor pages per global broad bucket per run
HARVEST_GENRES_PER_RUN=4         # round-robin genre slices fetched per media type per run

# ── Misc (defaults are fine) ─────────────────────────────────────────────────
PORT=8094
DB_PATH=./data/tastebuds.db
